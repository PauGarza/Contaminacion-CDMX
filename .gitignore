# ============================================
# Gitignore — Contaminacion-CDMX
# ============================================

# Directorio de archivos obsoletos
archive/

# Datos crudos descargados (regenerables via scripts)
data/raw/*.csv

# Archivos de modelo grandes (regenerables via scripts)
output/*.RData
output/figures/*.RData

# Figuras (regenerables via scripts)
output/figures/*.png

# Shapefiles grandes
data/gadm_mexico/
data/*.zip

# R temporales
.Rhistory
.RData
.RDataTmp
.Rproj.user/

# LaTeX auxiliares
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz

# Windows
Thumbs.db
Desktop.ini

# Jupyter checkpoints (si aplica)
.ipynb_checkpoints/

# Claude Code — archivos de instrucciones y configuracion local
.claude/
CLAUDE.md

# Kimi temporales
*.tmp
